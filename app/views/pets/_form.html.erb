<%= form_with(model: pet, local: true, html: { multipart: true }) do |f| %>

  <!-- ERRORES -->
  <%= render "shared/error_messages", object: pet %>

  <!-- NAME -->
  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <!-- SPECIES -->
  <div class="mb-3">
    <%= f.label :species, class: "form-label" %>
    <%= f.select :species,
        ["dog", "cat", "rabbit", "bird", "reptile", "other"],
        {},
        class: "form-select" %>
  </div>

  <!-- BREED -->
  <div class="mb-3">
    <%= f.label :breed, class: "form-label" %>
    <%= f.text_field :breed, class: "form-control" %>
  </div>

  <!-- DATE OF BIRTH -->
  <div class="mb-3">
    <%= f.label :date_of_birth, class: "form-label" %>
    <%= f.date_field :date_of_birth, class: "form-control" %>
  </div>

  <!-- WEIGHT -->
  <div class="mb-3">
    <%= f.label :weight, class: "form-label" %>
    <%= f.number_field :weight, step: 0.1, class: "form-control" %>
  </div>

  <!-- OWNER -->
  <div class="mb-3">
    <%= f.label :owner_id, "Owner", class: "form-label" %>

    <%= f.collection_select :owner_id,
        Owner.all,
        :id,
        :full_name,
        { prompt: "Select owner" },
        class: "form-select" %>
  </div>

  <!-- PHOTO -->
  <div class="mb-3">
    <%= f.label :photo, class: "form-label" %>

    <%= f.file_field :photo,
          class: "form-control",
          accept: "image/png,image/jpeg,image/webp" %>
  </div>

  <!-- PHOTO PREVIEW -->
  <% if pet.photo.attached? %>
    <div class="mb-3">
      <p class="fw-semibold mb-2">Current photo:</p>

      <%= image_tag pet.photo.variant(resize_to_limit: [300, 300]),
            class: "img-fluid rounded shadow-sm" %>
    </div>
  <% end %>

  <!-- SUBMIT -->
  <%= f.submit "Save Pet", class: "btn btn-primary" %>

<% end %>
