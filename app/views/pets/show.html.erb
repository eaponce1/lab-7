<h1 class="mb-4 fw-bold text-center"><%= @pet.name %></h1>

<div class="card">
  <div class="card-body">

    <!-- FOTO -->
    <div class="text-center mb-4">
      <% if @pet.photo.attached? %>
        <%= image_tag @pet.photo,
              class: "img-fluid rounded shadow",
              style: "max-width: 300px;" %>
      <% else %>
        <div class="alert alert-secondary">
          No photo available
        </div>
      <% end %>
    </div>

    <!-- INFO -->
    <div class="mb-3">
      <p>
        <strong>Species:</strong>
        <span class="badge bg-info text-dark">
          <%= @pet.species %>
        </span>
      </p>

      <p><strong>Breed:</strong> <%= @pet.breed %></p>

      <p>
        <strong>Birth Date:</strong>
        <%= @pet.date_of_birth&.strftime("%B %d, %Y") %>
      </p>

      <p><strong>Weight:</strong> <%= @pet.weight %> kg</p>

      <p>
        <strong>Owner:</strong>
        <%= link_to "#{@pet.owner.first_name} #{@pet.owner.last_name}", @pet.owner %>
      </p>
    </div>

    <hr>

    <!-- APPOINTMENTS -->
    <h4 class="mt-4">Appointments</h4>

    <% if @pet.appointments.any? %>
      <table class="table table-striped mt-3">
        <thead>
          <tr>
            <th>Reason</th>
            <th>Date</th>
            <th>Vet</th>
          </tr>
        </thead>

        <tbody>
          <% @pet.appointments.each do |a| %>
            <tr>
              <td>
                <%= link_to a.reason, a %>
              </td>

              <td>
                <%= a.date&.strftime("%B %d, %Y") %>
              </td>

              <td>
                <%= "#{a.vet.first_name} #{a.vet.last_name}" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="alert alert-info mt-3">
        No appointments yet
      </div>
    <% end %>

    <hr>

    <!-- ACTIONS -->
    <div class="d-flex gap-2">

      <%= link_to "Edit", edit_pet_path(@pet), class: "btn btn-warning" %>

      <%= button_to "Delete", @pet,
            method: :delete,
            data: { turbo_confirm: "Are you sure?" },
            class: "btn btn-danger" %>

      <%= link_to "Back", pets_path, class: "btn btn-secondary" %>

    </div>

  </div>
</div>
