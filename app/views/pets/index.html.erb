<%= link_to "New Pet", new_pet_path, class: "btn btn-primary mb-3" %>

<h1 class="mb-4 fw-bold">Pets</h1>

<div class="table-responsive">
  <table class="table table-striped table-hover align-middle">

    <thead class="table-dark">
      <tr>
        <th>Photo</th>
        <th>Name</th>
        <th>Species</th>
        <th>Breed</th>
        <th>Owner</th>
        <th>Birth Date</th>
        <th class="text-center">Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @pets.each do |pet| %>
        <tr>

          <!-- PHOTO -->
          <td>
            <% if pet.photo.attached? %>
              <%= image_tag pet.photo.variant(resize_to_fill: [60, 60]).processed,
                    class: "rounded shadow-sm",
                    style: "object-fit: cover;" %>
            <% else %>
              <span class="text-muted">No photo</span>
            <% end %>
          </td>

          <!-- NAME -->
          <td>
            <%= link_to pet.name, pet, class: "fw-semibold text-decoration-none" %>
          </td>

          <!-- SPECIES -->
          <td>
            <span class="badge bg-info text-dark">
              <%= pet.species %>
            </span>
          </td>

          <!-- BREED -->
          <td><%= pet.breed %></td>

          <!-- OWNER -->
          <td>
            <%= link_to "#{pet.owner.first_name} #{pet.owner.last_name}",
                        pet.owner,
                        class: "text-decoration-none" %>
          </td>

          <!-- DATE -->
          <td>
            <%= pet.date_of_birth&.strftime("%B %d, %Y") %>
          </td>

          <!-- ACTIONS -->
          <td class="text-center">
            <div class="d-flex justify-content-center gap-2">

              <%= link_to "Show", pet, class: "btn btn-sm btn-outline-info" %>

              <%= link_to "Edit", edit_pet_path(pet), class: "btn btn-sm btn-outline-warning" %>

              <%= button_to "Delete", pet,
                    method: :delete,
                    data: { turbo_confirm: "Are you sure?" },
                    form: { class: "d-inline" },
                    class: "btn btn-sm btn-outline-danger" %>

            </div>
          </td>

        </tr>
      <% end %>
    </tbody>

  </table>
</div>