<%= link_to "New Pet", new_pet_path, class: "btn btn-primary mb-3" %>

<h1 class="mb-4 fw-bold">Pets</h1>

<div class="table-responsive">
  <table class="table table-striped table-hover align-middle">

    <thead class="table-dark">
      <tr>
        <th>Name</th>
        <th>Species</th>
        <th>Breed</th>
        <th>Owner</th>
        <th>Birth Date</th>
        <th class="text-center">Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @pets.each do |pet| %>
        <tr>

          <!-- Name -->
          <td>
            <%= link_to pet.name, pet, class: "fw-semibold text-decoration-none" %>
          </td>

          <!-- Species -->
          <td>
            <span class="badge bg-info text-dark">
              <%= pet.species %>
            </span>
          </td>

          <!-- Breed -->
          <td><%= pet.breed %></td>

          <!-- Owner -->
          <td>
            <%= link_to "#{pet.owner.first_name} #{pet.owner.last_name}", pet.owner, class: "text-decoration-none" %>
          </td>

          <!-- Birth Date -->
          <td>
            <%= pet.date_of_birth&.strftime("%B %d, %Y") %>
          </td>

          <!-- ACTIONS (BONITO Y ORDENADO) -->
          <td class="text-center">
            <div class="d-flex justify-content-center gap-2">

              <%= link_to "Show", pet, class: "btn btn-sm btn-outline-info" %>

              <%= link_to "Edit", edit_pet_path(pet), class: "btn btn-sm btn-outline-warning" %>

              <%= button_to "Delete", pet,
                    method: :delete,
                    data: { turbo_confirm: "Are you sure?" },
                    form: { class: "d-inline" },
                    class: "btn btn-sm btn-outline-danger" %>

            </div>
          </td>

        </tr>
      <% end %>
    </tbody>

  </table>
</div>