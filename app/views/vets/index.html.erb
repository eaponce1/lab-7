<%= link_to "New Vet", new_vet_path, class: "btn btn-primary mb-3" %>

<h1 class="mb-4 fw-bold">Vets</h1>

<div class="table-responsive">
  <table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Specialization</th>
        <th class="text-center">Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @vets.each do |vet| %>
        <tr>

          <td>
            <%= link_to "#{vet.first_name} #{vet.last_name}", vet %>
          </td>

          <td><%= vet.email %></td>

          <td>
            <span class="badge bg-info text-dark">
              <%= vet.specialization %>
            </span>
          </td>

          <td class="text-center">
            <div class="btn-group" role="group">

              <%= link_to "Show", vet, class: "btn btn-sm btn-info text-white" %>

              <%= link_to "Edit", edit_vet_path(vet), class: "btn btn-sm btn-warning" %>

              <%= button_to "Delete",
                  vet_path(vet),
                  method: :delete,
                  data: { turbo_confirm: "Are you sure?" },
                  class: "btn btn-sm btn-danger" %>

            </div>
          </td>

        </tr>
      <% end %>
    </tbody>
  </table>
</div>