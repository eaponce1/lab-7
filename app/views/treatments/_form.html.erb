<%= form_with(model: [@appointment, @treatment], data: { turbo: false }) do |f| %>

  <!-- ERRORES -->
  <%= render "shared/error_messages", object: @treatment %>

  <!-- NAME -->
  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <!-- DATE -->
  <div class="mb-3">
    <%= f.label :administered_at, class: "form-label" %>
    <%= f.datetime_local_field :administered_at, class: "form-control" %>
  </div>

  <!-- ACTION TEXT -->
  <div class="mb-3">
    <%= f.label :clinical_notes, class: "form-label" %>
    <%= f.rich_text_area :clinical_notes, class: "form-control" %>
  </div>

  <!-- ACTIONS -->
  <div class="d-flex gap-2 mt-3">
    <%= f.submit "Save Treatment", class: "btn btn-primary" %>

    <%= link_to "Cancel",
          @appointment,
          class: "btn btn-secondary" %>
  </div>

<% end %>