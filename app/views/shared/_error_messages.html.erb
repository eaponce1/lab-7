<% if object.errors.any? %>
  <div class="alert alert-danger">
    <h5><%= pluralize(object.errors.count, "error") %> prevented this record from being saved:</h5>

    <ul class="mb-0">
      <% object.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>