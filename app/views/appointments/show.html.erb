<h1 class="mb-4">Appointment Details</h1>

<div class="card">
  <div class="card-body">

    <p><strong>Date:</strong> <%= @appointment.date.strftime("%B %d, %Y") %></p>

    <p>
      <strong>Pet:</strong>
      <%= link_to @appointment.pet.name, @appointment.pet %>
    </p>

    <p>
      <strong>Vet:</strong>
      <%= link_to "#{@appointment.vet.first_name} #{@appointment.vet.last_name}", @appointment.vet %>
    </p>

    <p><strong>Reason:</strong> <%= @appointment.reason %></p>

    <p>
      <strong>Status:</strong>
      <span class="badge
        <%= case @appointment.status
            when "scheduled" then "bg-primary"
            when "in_progress" then "bg-warning text-dark"
            when "completed" then "bg-success"
            when "cancelled" then "bg-danger"
            end %>">
        <%= @appointment.status.humanize %>
      </span>
    </p>

    <hr>

    <!-- TREATMENTS -->
    <div class="d-flex justify-content-between align-items-center mt-4">
      <h4 class="mb-0">Treatments</h4>

      <%= link_to "New Treatment",
            new_appointment_treatment_path(@appointment),
            class: "btn btn-primary" %>
    </div>

    <% if @appointment.treatments.any? %>

      <% @appointment.treatments.each do |t| %>
        <div class="card mt-3">
          <div class="card-body">

            <div class="d-flex justify-content-between align-items-start">

              <div>
                <h5 class="mb-1"><%= t.name %></h5>
                <small class="text-muted">
                  <%= t.administered_at&.strftime("%B %d, %Y %H:%M") %>
                </small>
              </div>

              <div class="d-flex gap-2">
                <%= link_to "Edit",
                      edit_appointment_treatment_path(@appointment, t),
                      class: "btn btn-sm btn-outline-warning" %>

                <%= button_to [@appointment, t],
                      method: :delete,
                      data: { turbo_confirm: "Are you sure?" },
                      form: { class: "d-inline" },
                      class: "btn btn-sm btn-outline-danger" do %>
                  Delete
                <% end %>
              </div>

            </div>

            <hr>

            <!-- CLINICAL NOTES -->
            <div class="mt-2">
              <%= t.clinical_notes %>
            </div>

          </div>
        </div>
      <% end %>

    <% else %>

      <div class="alert alert-info mt-3">
        No treatments yet.
      </div>

    <% end %>

  </div>
</div>