<%= link_to "New Appointment", new_appointment_path, class: "btn btn-primary mb-3" %>

<h1 class="mb-4 fw-bold">Appointments</h1>

<!-- FILTROS -->
<div class="mb-3">
  <%= link_to "All", appointments_path, class: "btn btn-dark me-2" %>
  <%= link_to "Past", past_appointments_path, class: "btn btn-secondary" %>
</div>

<div class="table-responsive">
  <table class="table table-striped table-hover align-middle">

    <thead class="table-dark">
      <tr>
        <th>Date</th>
        <th>Pet</th>
        <th>Vet</th>
        <th>Reason</th>
        <th class="text-center">Status</th>
        <th class="text-center">Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @appointments.each do |a| %>
        <tr>

          <!-- Date -->
          <td>
            <%= a.date&.strftime("%B %d, %Y") %>
          </td>

          <!-- Pet -->
          <td>
            <%= link_to a.pet.name, a.pet, class: "fw-semibold text-decoration-none" %>
          </td>

          <!-- Vet -->
          <td>
            <%= link_to "#{a.vet.first_name} #{a.vet.last_name}", a.vet, class: "text-decoration-none" %>
          </td>

          <!-- Reason -->
          <td>
            <%= a.reason %>
          </td>

          <!-- Status -->
          <td class="text-center">
            <span class="badge
              <%= case a.status
                  when "scheduled" then "bg-primary"
                  when "in_progress" then "bg-warning text-dark"
                  when "completed" then "bg-success"
                  when "cancelled" then "bg-danger"
                  end %>">
              <%= a.status.humanize %>
            </span>
          </td>

          <!-- ACTIONS -->
          <td class="text-center">
            <div class="d-flex justify-content-center gap-2">

              <%= link_to "Show", a, class: "btn btn-sm btn-outline-info" %>

              <%= link_to "Edit", edit_appointment_path(a), class: "btn btn-sm btn-outline-warning" %>

              <%= button_to "Delete", a,
                    method: :delete,
                    data: { turbo_confirm: "Are you sure?" },
                    form: { class: "d-inline" },
                    class: "btn btn-sm btn-outline-danger" %>

            </div>
          </td>

        </tr>
      <% end %>
    </tbody>

  </table>
</div>